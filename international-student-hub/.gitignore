# =============================================================================
# .gitignore — International Student Hub
# =============================================================================

# --------------------------------------------------------------------------
# CRITICAL: Never commit these
# --------------------------------------------------------------------------
.env
*.env
.env.*
!.env.example              # Keep the example file for onboarding

# --------------------------------------------------------------------------
# Python
# --------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
.mypy_cache/
.dmypy.json

# --------------------------------------------------------------------------
# Django
# --------------------------------------------------------------------------
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
staticfiles/
mediafiles/

# --------------------------------------------------------------------------
# Virtual environments
# --------------------------------------------------------------------------
venv/
env/
ENV/
.venv/

# --------------------------------------------------------------------------
# Node / React frontend
# --------------------------------------------------------------------------
node_modules/
frontend/dist/
frontend/build/
.npm

# --------------------------------------------------------------------------
# Docker
# --------------------------------------------------------------------------
# Don't ignore docker-compose.override.yml — useful for local customisation
# but add it if you don't want it tracked:
# docker-compose.override.yml

# --------------------------------------------------------------------------
# IDE / Editor
# --------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# --------------------------------------------------------------------------
# Test & Coverage
# --------------------------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/
coverage.xml
